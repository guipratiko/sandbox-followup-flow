# Copie para EasyPanel / Docker. Em dev, ajuste e use `npm run dev`.
PORT=4337
NODE_ENV=production

# Mesmo Postgres do backend OnlyFlow
POSTGRES_URI=postgres://user:pass@host:5432/dbname?sslmode=disable

# Mesmo JWT_SECRET do backend OnlyFlow
JWT_SECRET=your-secret-key-change-in-production

# Obrigatório: URL do backend OnlyFlow (worker verifica plano pago/free aqui)
# Sandbox: https://back-sandbox.onlyflow.com.br
# Produção: https://back.onlyflow.com.br
ONLYFLOW_API_BASE_URL=https://back-sandbox.onlyflow.com.br

# Evolution (mesmos valores que o backend usa para envio Baileys)
EVOLUTION_API_BASE_URL=https://evo.onlyflow.com.br
EVOLUTION_API_KEY=
EVOLUTION_INSECURE_TLS=true

# CORS opcional (origens separadas por vírgula)
CORS_ORIGINS=https://sandbox.onlyflow.com.br

# Opcional: mesmo REDIS_URI do backend — invalida cache do chat após espelhar mensagem
# REDIS_URI=redis://...

# Opcional: mesma chave interna do backend (se omitir, usa JWT_SECRET)
# ONLYFLOW_INTERNAL_KEY=

# Opcional: mesmo FOLLOWUP_MIRROR_NOTIFY_SECRET do backend
# FOLLOWUP_MIRROR_NOTIFY_SECRET=
