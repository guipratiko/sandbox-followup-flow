# Health público neste serviço: GET /api/public/status (o backend OnlyFlow agrega em /api/public/status)
# Porta HTTP do microserviço (EasyPanel / Docker)
PORT=4337
NODE_ENV=production

# Mesmo Postgres do backend OnlyFlow (POSTGRES_URI no .env do backend)
POSTGRES_URI=postgres://user:pass@host:5432/dbname?sslmode=disable

# Opcional: mesmo REDIS_URI do backend — após espelhar a mensagem no CRM, invalida cache do chat
# REDIS_URI=redis://...

# Mesmo JWT_SECRET do backend — valida Bearer enviado pelo proxy / front
JWT_SECRET=your-secret-key-change-in-production

# Evolution API (envio WhatsApp não-oficial / Baileys) — URL absoluta (https://...); host sem esquema é normalizado para https
EVOLUTION_API_BASE_URL=https://sua-evolution.com
EVOLUTION_API_KEY=
# EVOLUTION_INSECURE_TLS=true

# CORS: origens permitidas separadas por vírgula (vazio = regra padrão OnlyFlow + dev)
# CORS_ORIGINS=https://app.onlyflow.com.br
